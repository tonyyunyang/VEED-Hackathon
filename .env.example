# Optional: override the frontend dev/preview proxy target.
# VITE_BACKEND_TARGET=http://localhost:8000

FAL_KEY=your_fal_api_key_here
RUNWARE_API_KEY=your_runware_api_key_here
# Optional: leave unset to use ./server/storage
# STORAGE_DIR=/absolute/path/to/storage
ENABLE_LIPSYNC=false
LIPSYNC_RESOLUTION=480p
# Swap backend used by /api/swap.
# `facefusion` is the easiest local setup because it uses the included submodule.
# `insightface` requires server/models/inswapper_128.onnx to exist.
FACE_SWAPPER_BACKEND=facefusion
# Metadata enrichment runs InsightFace over a representative crop to fill age,
# gender, and embeddings. It defaults to false when FACE_SWAPPER_BACKEND=facefusion.
# ENABLE_FACE_METADATA_ENRICHMENT=true
# Optional single reference image used for all swaps.
# FACE_SWAP_REFERENCE_IMAGE=/absolute/path/to/source-face.jpg
# Optional reference-face library under this repo. Supported layout:
# server/reference_faces/male/*.jpg
# server/reference_faces/female/*.jpg
# Filenames may include age ranges like 20-29_actor.jpg for age matching.
FACE_SWAP_REFERENCE_FACES_DIR=server/reference_faces
FACE_SWAP_ALLOW_TARGET_THUMBNAIL_FALLBACK=true
# Local FaceFusion checkout and runtime settings. Leave FACEFUSION_PYTHON unset to use
# the same Python interpreter that started the server.
FACEFUSION_DIR=facefusion-VEED
# FACEFUSION_PYTHON=/absolute/path/to/python
# FACEFUSION_EXECUTION_PROVIDER=coreml
FACEFUSION_BYPASS_CONTENT_ANALYSER=true
FACEFUSION_SWAP_MODEL=hyperswap_1a_256
FACEFUSION_PIXEL_BOOST=512x512
FACEFUSION_ENABLE_ENHANCER=true
FACEFUSION_OUTPUT_VIDEO_QUALITY=90
FACEFUSION_THREAD_COUNT=4
FACEFUSION_KEEP_INTERMEDIATES=false
TRACKER_BACKEND=movie_like_shots
TRACKER_TYPE=ocsort
TRACKER_DEVICE=auto
FACE_ANALYSIS_DEVICE=auto
TRACKER_DET_SIZE=640
TRACKER_DET_THRESH=0.35
TRACKER_NMS_THRESH=0.4
TRACKER_NUM_BINS=64
TRACKER_SHOT_CHANGE_THRESHOLD=0.4
TRACKER_SIMILARITY_THRESHOLD=0.4
TRACKER_FILTER_TRACKS=false
TRACKER_MIN_TRACK_LENGTH=10
TRACKER_MIN_TRACK_MEDIAN_AREA=2500.0
TRACKER_FILTER_CONFIDENCE=false
TRACKER_MIN_CONFIDENCE=0.5
TRACKER_USE_SHOT_CHANGE=true
TRACKER_USE_SHARED_MEMORY=true
TRACKER_TIMEOUT_SECONDS=600
FRAME_SUBSAMPLE=5
DUMMY_TRACKING=false
